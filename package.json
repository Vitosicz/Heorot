{
  "name": "heorot-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "setup:linux": "pnpm install --ignore-scripts && pnpm rebuild electron esbuild",
    "dev": "npm run dev:web",
    "build": "npm run build:web",
    "preview": "npm run preview:web",
    "typecheck": "npm run typecheck:web",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "preview:web": "npm --prefix apps/web run preview",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "build:desktop": "npm --prefix apps/desktop run build",
    "dist:desktop": "npm --prefix apps/desktop run dist",
    "dist:linux": "npm --prefix apps/desktop run dist:linux",
    "dist:mac": "npm --prefix apps/desktop run dist:mac",
    "dist:mac:universal:unsigned": "npm --prefix apps/desktop run dist:mac:universal:unsigned",
    "dist:mac:universal:signed": "npm --prefix apps/desktop run dist:mac:universal:signed",
    "build:all": "npm run build:web && npm run build:desktop"
  }
}
